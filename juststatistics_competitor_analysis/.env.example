# ============================================================
# .env.example — copy to .env and fill all values
# NEVER commit .env to git
# ============================================================

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key

# --- PostgreSQL ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=replace-with-strong-password
# App user (least-privilege — what n8n connects with day-to-day)
POSTGRES_NON_ROOT_USER=n8n_app
POSTGRES_NON_ROOT_PASSWORD=replace-with-strong-password

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-strong-password
# Generate: openssl rand -hex 16
N8N_ENCRYPTION_KEY=replace-with-32-char-hex
N8N_HOST=your-domain.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-domain.com/

# --- Monitoring ---
# BetterUptime / UptimeRobot heartbeat URL
# Leave empty to skip heartbeat pings
HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/replace-with-token

# --- Scraping APIs (optional — add as integrations are built) ---
BRIGHTDATA_API_KEY=
APIFY_API_TOKEN=
